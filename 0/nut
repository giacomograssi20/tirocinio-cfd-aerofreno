FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      nut;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// nut [m2/s]
dimensions      [0 2 -1 0 0 0 0];
internalField   uniform 1e-5;

boundaryField
{
    // Rebuilt from mesh by the GUI.
    // Typical wall BC:
    //   type nutkWallFunction; value uniform 0;

    inlet       { type calculated; value uniform 1e-5; }
    outlet      { type calculated; value uniform 1e-5; }
    walls       { type nutkWallFunction; value uniform 0; }
    aerofreno    { type nutkWallFunction; value uniform 0; }
 
}
